# CONFIGURACIÓN BACKEND - RESTAURANTE ESCOLAR

NODE_ENV=development
PORT=5000

# CONFIGURACIÓN DE BASE DE DATOS
DB_HOST=localhost
DB_PORT=3306
DB_NAME=restaurante_escolar_db
DB_USER=root
DB_PASSWORD=

# CONFIGURACIÓN DE IA - GEMINI
GEMINI_API_KEY=TU_CLAVE_DE_API_AQUI

# CONFIGURACIÓN JWT
JWT_SECRET=generar_una_clave_aleatoria_segura
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=generar_otra_clave_aleatoria_segura
JWT_REFRESH_EXPIRES_IN=7d

# CONFIGURACIÓN DE RED
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CONFIGURACIÓN DE EMAIL (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion
EMAIL_FROM="Restaurante Escolar <tu_correo@gmail.com>"

# CONFIGURACIÓN DE ARCHIVOS
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# SEGURIDAD
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# FRONTEND URL
FRONTEND_URL=http://localhost:5173
