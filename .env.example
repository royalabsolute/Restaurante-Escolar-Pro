# CONFIGURACIÓN UNIFICADA - FRONTEND RESTAURANTE ESCOLAR  
# Variables para Vite - DEBEN empezar con VITE_ para ser accesibles

VITE_APP_BASE_NAME=/
VITE_PORT=5173

# CONFIGURACIÓN DE BACKEND
VITE_API_URL_FALLBACK=http://localhost:5000
VITE_BACKEND_PORTS=5000,3000,8000

# NGROK - ACCESO REMOTO (Opcional)
# VITE_BACKEND_NGROK_URL=

# CONFIGURACIÓN DE LOGS
VITE_LOG_LEVEL=info

# CONFIGURACIÓN DE RED
VITE_NETWORK_HOST=0.0.0.0

# CONFIGURACIÓN DE DESARROLLO
VITE_ENABLE_DEVTOOLS=false
